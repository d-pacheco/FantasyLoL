# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fantasy_lol"

# Debug
DEBUG_LOGGING=True

# CORS (comma-separated origins, or ["*"] to allow all)
CORS_ORIGINS=["*"]

# Auth (required — no defaults)
AUTH_SECRET="change-me-to-a-secure-random-string"
AUTH_ALGORITHM="HS256"

# Logging (Loki/Grafana — optional, disabled by default)
LOKI_ENABLED=False
LOKI_URL="http://localhost:3100/loki/api/v1/push"

# Email Verification
REQUIRE_EMAIL_VERIFICATION=True
VERIFICATION_DOMAIN_URL="http://localhost"
VERIFICATION_SENDER_EMAIL="your-email@gmail.com"
VERIFICATION_SENDER_PASSWORD="your-app-password"
VERIFICATION_SMTP_HOST="smtp.gmail.com"
VERIFICATION_SMTP_PORT=465
